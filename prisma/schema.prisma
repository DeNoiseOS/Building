// DeNoise OS V1.0A Prisma schema
// V0.2 collaboration layer + V1.0A Departments foundation.
// Departments are first-class entities under a Project. Tasks, Notes,
// References, and memberships can be department-scoped via optional FKs.
// The role + section vocabulary remains as the migration seed and the
// Workspace presentation hint.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // Prisma 7: URLs no longer belong in the schema. The migrate URL lives
  // in `prisma.config.ts` (uses DIRECT_URL); runtime queries go through
  // the pg driver adapter in `lib/prisma.ts` (uses DATABASE_URL).
  provider = "postgresql"
}

model User {
  id              String              @id @default(cuid())
  name            String
  email           String              @unique
  password        String
  createdAt       DateTime            @default(now())

  // V0.12 — Profile / Talent Foundation. All optional so existing rows
  // remain valid; profile completion is derived from how many of these
  // are filled (see lib/profile-completion.ts).
  profileImage      String?
  primaryRole       String?           // canonical role string (lib/roles.ts)
  additionalRoles   String[]          @default([])
  experienceLevel   String?           // "junior" | "mid" | "senior" | "lead"
  location          String?           // free-form, e.g. "Riyadh, SA"
  languages         String[]          @default([])  // ISO-639-1 codes
  contactPhone      String?
  contactWebsite    String?
  portfolioLinks    Json?             // [{ title: string, url: string }]
  profileSkippedAt  DateTime?         // when user dismissed the completion banner
  projects        Project[]
  assignedTasks   Task[]              @relation("TaskAssignee")
  memberships     ProjectMember[]
  invitationsSent ProjectInvitation[] @relation("InvitationSender")
  departmentMemberships DepartmentMember[]
  // V0.5 workflow layer
  createdTasks    Task[]              @relation("TaskCreator")
  approverTasks   Task[]              @relation("TaskApprover")
  notifications   Notification[]
  // V0.6 budget requests
  budgetRequests  BudgetRequest[] @relation("BudgetRequester")
  // V0.6.1 comments
  comments        Comment[]
  // V0.7 announcements (authored)
  announcements   Announcement[] @relation("AnnouncementAuthor")
  // V0.9 custodies
  custodiesHeld   Custody[]      @relation("CustodyHolder")
  custodiesIssued Custody[]      @relation("CustodyIssuer")
  // V0.10 equipment
  equipmentAssigned EquipmentAssignment[] @relation("EquipmentAssignee")
  equipmentIssued   EquipmentAssignment[] @relation("EquipmentIssuer")
  damageReports     DamageReport[]
  // V0.16
  equipmentReturned EquipmentAssignment[] @relation("EquipmentReturner")
  maintenanceLogged MaintenanceRecord[]
  // V0.13 purchases
  purchasesCreated  Purchase[] @relation("PurchaseCreator")
  purchasesAssigned Purchase[] @relation("PurchaseAssignee")
  // V0.14.1 custody requests
  custodyRequestsMade     CustodyRequest[] @relation("CustodyRequestRequester")
  custodyRequestsDecided  CustodyRequest[] @relation("CustodyRequestDecider")
  // V0.17 scenes
  scenesCreated           Scene[]             @relation("SceneCreator")
  scenesUpdated           Scene[]             @relation("SceneUpdater")
  sceneDeptApprovals      SceneDepartment[]   @relation("SceneDeptApprover")
  // V0.18
  sceneAssetsAdded        SceneAsset[]        @relation("SceneAssetAdder")
  // V0.20 — Production Bible authorship.
  bibleEntries            BibleEntry[]        @relation("BibleEntryAuthor")
  // V0.23 — File uploads.
  attachmentsUploaded     Attachment[]        @relation("AttachmentUploader")
  // V0.24 — Agency access.
  sceneComments           SceneComment[]      @relation("SceneCommentAuthor")
  creativeApprovalsRequested CreativeApproval[] @relation("CreativeApprovalRequester")
  creativeApprovalsDecided   CreativeApproval[] @relation("CreativeApprovalDecider")
  // V0.25 — Cast.
  talentsCreated          Talent[]            @relation("TalentCreator")
  sceneCastAdded          SceneCast[]         @relation("SceneCastAdder")
}

model Project {
  id          String              @id @default(cuid())
  userId      String
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String?
  role        String
  startDate   DateTime
  endDate     DateTime
  status      String              @default("active")
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  tasks       Task[]
  notes       Note[]
  references  Reference[]
  activities  Activity[]
  members     ProjectMember[]
  invitations ProjectInvitation[]
  departments Department[]
  budgetRequests BudgetRequest[]
  // V0.6.1 — true project budget
  /// Total project budget in minor units (cents-equivalent). NULL = not set.
  totalBudget Int?
  /// V0.11 — Project currency (one of SUPPORTED_CURRENCIES). Defaults to SAR.
  /// Inherited by every financial module (budgets, custodies, expenses).
  currency    String  @default("SAR")
  departmentBudgets DepartmentBudget[]
  comments    Comment[]
  // V0.7
  announcements Announcement[]
  // V0.9 + V0.10
  custodies   Custody[]
  equipment   Equipment[]
  // V0.13
  purchases   Purchase[]
  // V0.14.1
  custodyRequests CustodyRequest[]
  // V0.17
  scenes      Scene[]
  // V0.20
  bibleEntries BibleEntry[]
  // V0.23
  attachments Attachment[]
  // V0.24
  creativeApprovals CreativeApproval[]
  // V0.25
  talents     Talent[]

  @@index([userId])
  @@index([status])
}

/// A user's membership in a project. Owner is also represented here
/// (auto-created when a project is created). Role here can differ from
/// Project.role (the project's primary role discipline).
model ProjectMember {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String
  joinedAt  DateTime @default(now())

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
}

/// An invitation to join a project. Targets an email (so we can invite
/// people who haven't registered yet). When that email matches an existing
/// User, it appears in their pending invitations immediately. Otherwise it
/// stays pending until that email registers.
model ProjectInvitation {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  email     String
  role      String
  invitedBy String
  inviter   User     @relation("InvitationSender", fields: [invitedBy], references: [id], onDelete: Cascade)
  status    String   @default("pending")
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@unique([projectId, email])
  @@index([email])
  @@index([projectId])
  @@index([status])
}

model Task {
  id          String    @id @default(cuid())
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  /// V1.0A: optional department ownership. NULL = legacy / no department.
  /// V0.5 treats this field as `ownerDepartmentId` — the department that
  /// owns the task. Column name preserved for backwards compat.
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  assigneeId  String?
  assignee    User?     @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  /// V0.5 — who created the task (for visibility + audit).
  creatorId   String?
  creator     User?     @relation("TaskCreator", fields: [creatorId], references: [id], onDelete: SetNull)
  /// V0.5 — explicit approver override; if null, approval falls back to
  /// the owner-department head / director / producer per hierarchy.
  approverId  String?
  approver    User?     @relation("TaskApprover", fields: [approverId], references: [id], onDelete: SetNull)
  title       String
  description String?
  status      String    @default("todo")
  priority    String    @default("medium")
  section     String?
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([projectId])
  @@index([departmentId])
  @@index([assigneeId])
  @@index([creatorId])
  @@index([approverId])
  @@index([status])
  @@index([dueDate])
}

model Note {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  title     String
  body      String
  section   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([departmentId])
  @@index([section])
}

model Reference {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  title       String
  description String?
  imageUrl    String?
  link        String?
  section     String
  createdAt   DateTime @default(now())

  @@index([projectId])
  @@index([departmentId])
  @@index([section])
}

/// V0.2 adds actorId/actorName so every activity entry tells you who did
/// what. Both nullable to allow legacy rows; backfilled at migration time
/// from the project owner.
model Activity {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  actorId   String?
  actorName String?
  type      String
  message   String
  metadata  String?
  createdAt DateTime @default(now())

  @@index([projectId])
  @@index([actorId])
  @@index([createdAt])
  @@index([type])
}

/// V1.0A: a Department is a first-class entity under a Project. It owns
/// people (DepartmentMember), tasks, notes, and references. The migration
/// seeds one Department per distinct role in each project. New departments
/// can be created by the project owner.
model Department {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  /// Stable slug, unique within a project. Defaults to the kind value.
  key       String
  name      String
  /// Department class — drives default icon and section composition mapping.
  /// V0.10.1: matches the registry's `headRole` (e.g. "art_director",
  /// "director_of_photography") or a legacy alias.
  kind      String
  /// V0.10.1 — resource type label for the department's resources tab.
  /// One of: equipment, props, talent, location_assets, deliverables, documents.
  resourceType String   @default("equipment")
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members    DepartmentMember[]
  tasks      Task[]
  notes      Note[]
  references Reference[]
  budgetRequests BudgetRequest[]
  budget     DepartmentBudget?
  // V0.9 + V0.10
  custodies  Custody[]
  equipment  Equipment[]
  // V0.13
  purchases  Purchase[]
  // V0.14.1
  custodyRequests CustodyRequest[]
  // V0.16 — equipment assigned to this dept (not a specific person)
  equipmentAssignments EquipmentAssignment[] @relation("EquipmentDeptAssignment")
  // V0.17 — scene workspaces
  sceneDepartments SceneDepartment[]
  // V0.20 — production bible entries scoped to this dept
  bibleEntries BibleEntry[]
  // V0.25 — talents (cast) scoped to this dept
  talents      Talent[]

  @@unique([projectId, key])
  @@index([projectId])
}

/// Department-scoped membership. A user can belong to many departments on
/// the same project. Role is "lead" or "member" (default).
model DepartmentMember {
  id           String     @id @default(cuid())
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  role         String     @default("member")
  joinedAt     DateTime   @default(now())

  @@unique([departmentId, userId])
  @@index([departmentId])
  @@index([userId])
}

/// V0.5 — In-app notifications. One row per delivered event; readAt set
/// when the user marks it read (or clicks through). No email / push.
model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  body      String?
  link      String?
  metadata  String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, readAt])
  @@index([userId, createdAt])
  @@index([type])
}

/// V0.6 — A budget request. Workflow only — NOT accounting.
/// Statuses: draft → submitted → approved | rejected → purchased.
model BudgetRequest {
  id            String     @id @default(cuid())
  projectId     String
  project       Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  departmentId  String
  department    Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  requesterId   String
  requester     User       @relation("BudgetRequester", fields: [requesterId], references: [id], onDelete: Cascade)

  /// V0.9 — optional link to a Custody. When set, the expense draws from
  /// that custody and contributes to its derived "remaining" balance.
  custodyId     String?
  custody       Custody?   @relation(fields: [custodyId], references: [id], onDelete: SetNull)

  title         String
  description   String?
  vendor        String?
  /// Stored as cents to avoid float drift. Display layer divides by 100.
  estimatedCost Int        @default(0)
  needByDate    DateTime?

  status        String     @default("draft")

  submittedAt   DateTime?
  approvedAt    DateTime?
  rejectedAt    DateTime?
  purchasedAt   DateTime?
  /// Optional reason captured when rejecting.
  rejectionReason String?

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([projectId])
  @@index([departmentId])
  @@index([requesterId])
  @@index([status])
}

/// V0.6.1 — DepartmentBudget. Producer assigns an allocation; department
/// head accepts / requests revision / rejects; final approvedAmount is
/// what's used for utilization math against PurchaseRequest totals.
///
/// Status machine:
///   pending → approved             (head accepts as-is)
///   pending → revision_requested   (head counters with new amount + reason)
///   revision_requested → approved  (producer settles on a final amount)
///   pending → rejected             (head refuses; reason captured)
model DepartmentBudget {
  id              String     @id @default(cuid())
  projectId       String
  project         Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  departmentId    String     @unique
  department      Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  /// Amount the producer assigned to this department (cents).
  allocatedAmount Int        @default(0)
  /// Amount the department head countered with (cents). NULL if no revision.
  requestedAmount Int?
  /// Final agreed amount once status = approved (cents).
  approvedAmount  Int?

  status          String     @default("pending")
  /// Department head's reason when rejecting or requesting a revision.
  reason          String?

  approvedAt      DateTime?
  rejectedAt      DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([projectId])
  @@index([status])
}

/// V0.6.1 / V0.7 — Polymorphic comments + discussion replies.
/// Targets:
///   task                  (Task.id)
///   purchase_request      (BudgetRequest.id)
///   budget_allocation     (DepartmentBudget.id)
///   note                  (Note.id)                  — V0.7
///   reference             (Reference.id)             — V0.7
///   department_discussion (Department.id)            — V0.7
///   announcement          (Announcement.id)          — V0.7
///
/// A reply is a Comment with `parentId` set; threading is one level deep.
model Comment {
  id         String   @id @default(cuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  authorId   String
  author     User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  targetType String
  targetId   String

  body       String

  /// V0.7 — reply threading. NULL = top-level comment.
  parentId   String?
  parent     Comment? @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies    Comment[] @relation("CommentReplies")

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([targetType, targetId])
  @@index([projectId])
  @@index([authorId])
  @@index([parentId])
}

/// V0.7 — Project Announcements. Posted by Owner / Producer / Director;
/// notify all project members. Optional pin (sort to top) and expiration.
model Announcement {
  id        String    @id @default(cuid())
  projectId String
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  authorId  String
  author    User      @relation("AnnouncementAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  title     String
  body      String
  pinned    Boolean   @default(false)
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([projectId])
  @@index([pinned])
  @@index([expiresAt])
}

// ─── V0.9 — Financial Operations ──────────────────────────────────────
/// Custody: actual money issued to a person. Tracks the "cash advance"
/// model used in production — producer hands out funds, holder spends
/// them via expenses, settles at the end.
///
/// "Remaining" is derived, never stored:
///   remaining = amount - sum(BudgetRequest.estimatedCost WHERE
///                            custodyId = this.id AND
///                            status = 'purchased')
model Custody {
  id           String   @id @default(cuid())
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  holderUserId String
  holder       User     @relation("CustodyHolder", fields: [holderUserId], references: [id], onDelete: Cascade)
  issuedByUserId String
  issuedBy     User     @relation("CustodyIssuer", fields: [issuedByUserId], references: [id], onDelete: Cascade)

  /// Amount issued in minor units (cents-equivalent).
  amount       Int
  currency     String   @default("USD")

  /// Status machine: active → (settlement requested) → settled OR cancelled.
  status       String   @default("active")
  settlementRequestedAt DateTime?
  settlementStatus      String?  // pending | approved (null when not requested)

  issuedAt     DateTime @default(now())
  settledAt    DateTime?
  notes        String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  expenses     BudgetRequest[]
  // V0.14.1 — Purchases linked to this custody.
  purchases    Purchase[]

  @@index([projectId])
  @@index([departmentId])
  @@index([holderUserId])
  @@index([status])
}

// ─── V0.10 — Asset Custody (Equipment) ────────────────────────────────
/// Equipment: physical asset tracked within a department.
/// Statuses: available, checked_out, returned, damaged, lost.
model Equipment {
  id           String   @id @default(cuid())
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  name         String
  serialNumber String?
  category     String?
  notes        String?

  /// V0.16 — Status vocabulary widened:
  ///   available | assigned | in_maintenance | damaged | retired
  /// Legacy values (available/damaged/lost) remain readable; "lost"
  /// is treated as "damaged" by analytics.
  status       String   @default("available")

  /// V0.18 — Inventory count for this equipment line. Defaults to 1
  /// for backwards compatibility (a single piece of gear). Increased
  /// when a Purchase records bulk items (e.g. "10 coffee cups").
  /// Used by SceneAsset shortage calculation.
  quantity     Int      @default(1)

  // V0.16 — Asset profile fields.
  /// Date the asset was purchased (independent of when the Equipment
  /// row was created). Optional; some assets are donated / inherited.
  purchaseDate DateTime?
  /// Cost paid at purchase, minor units (cents). Currency = project's.
  purchaseCost Int?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assignments    EquipmentAssignment[]
  damageReports  DamageReport[]
  // V0.16
  maintenanceRecords MaintenanceRecord[]
  // V0.18 — scenes that need this asset.
  sceneLinks     SceneAsset[]

  @@index([projectId])
  @@index([departmentId])
  @@index([status])
}

/// EquipmentAssignment: open assignment when returnedAt is NULL.
///
/// V0.16 — Check-out / check-in lifecycle:
///   - assignedToUserId is now nullable so an asset can be assigned to
///     a Department instead of a specific person (set
///     assignedToDepartmentId in that case). Exactly one is set.
///   - expectedReturnDate captures the planned return so the asset
///     list can surface "overdue" rows.
///   - returnedByUserId + returnCondition record the check-in.
model EquipmentAssignment {
  id              String   @id @default(cuid())
  equipmentId     String
  equipment       Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  /// V0.16 — nullable. NULL when the asset is checked out to a dept.
  assignedToUserId String?
  assignedTo       User?    @relation("EquipmentAssignee", fields: [assignedToUserId], references: [id], onDelete: Cascade)
  /// V0.16 — set when the asset is checked out to a department
  /// instead of a specific person.
  assignedToDepartmentId String?
  assignedToDepartment   Department? @relation("EquipmentDeptAssignment", fields: [assignedToDepartmentId], references: [id], onDelete: SetNull)

  assignedByUserId String
  assignedBy       User     @relation("EquipmentIssuer", fields: [assignedByUserId], references: [id], onDelete: Cascade)

  assignedAt   DateTime @default(now())
  /// V0.16 — planned return date (optional).
  expectedReturnDate DateTime?
  returnedAt   DateTime?
  /// V0.16 — who checked the asset back in. Usually = assignedToUserId
  /// but may differ when a head returns it on someone else's behalf.
  returnedByUserId String?
  returnedBy       User?    @relation("EquipmentReturner", fields: [returnedByUserId], references: [id], onDelete: SetNull)
  /// V0.16 — condition at check-in:
  /// excellent | good | fair | damaged
  returnCondition  String?
  notes        String?

  @@index([equipmentId])
  @@index([assignedToUserId])
  @@index([assignedToDepartmentId])
  @@index([returnedAt])
  @@index([expectedReturnDate])
}

/// DamageReport: incident report against a piece of equipment.
/// Severity: low | medium | high | critical.
/// V0.16 — Status vocabulary: open | under_review | resolved.
/// While open or under_review, the parent Equipment.status is
/// flipped to "damaged"; resolving may move it back to "available"
/// at the resolver's discretion.
model DamageReport {
  id               String   @id @default(cuid())
  equipmentId      String
  equipment        Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  reportedByUserId String
  reportedBy       User     @relation(fields: [reportedByUserId], references: [id], onDelete: Cascade)

  description      String
  severity         String   @default("low")
  status           String   @default("open")

  createdAt        DateTime @default(now())
  resolvedAt       DateTime?
  resolution       String?

  @@index([equipmentId])
  @@index([reportedByUserId])
  @@index([status])
  @@index([severity])
}

// ─── V0.13 — Purchases & Rentals ──────────────────────────────────────
//
// A unified record for every "we spent money on something" event. Two
// flavors share the same model:
//   - type=purchase  → permanent acquisition (props, consumables, fees)
//   - type=rental    → temporary use (cameras, vehicles, locations)
//
// Each Purchase belongs to a Department and is created by the dept head
// (the "issuer"). If the category is a Resource type (or the user
// explicitly flags it via saveAsResource), an Equipment row is created
// in the same transaction so the asset shows up under Resources.

model Purchase {
  id              String   @id @default(cuid())
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  departmentId    String
  department      Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  /// "purchase" | "rental"
  type            String

  /// Registry category key (e.g. "props", "construction", "lighting").
  /// "other" means the user typed their own categoryName.
  categoryKey     String
  /// Free-text label when categoryKey="other".
  customCategory  String?
  /// V0.13 — when the category is auto-Resource OR (category="other"
  /// AND user toggled "save as resource"), an Equipment row is created.
  saveAsResource  Boolean  @default(false)
  /// The auto-created Equipment.id (nullable; set when the toggle fired).
  equipmentId     String?  @unique

  name            String
  description     String?
  /// V0.13.1 — how many units of this item. Defaults to 1.
  quantity        Int      @default(1)
  /// Minor units (e.g. cents). Currency inherits from Project.
  /// This is the TOTAL amount for the whole line (quantity * unit price).
  amount          Int
  vendor          String?

  /// Optional assignee (a project member responsible for / receiving it).
  assigneeId      String?
  assignee        User?    @relation("PurchaseAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  /// Set for type=purchase.
  purchaseDate    DateTime?
  /// Set for type=rental.
  rentalStart     DateTime?
  rentalEnd       DateTime?

  /// URL to the uploaded receipt/invoice (Supabase Storage path or external).
  receiptUrl      String?

  /// V0.14.1 — link to the Custody the buyer was holding when the
  /// purchase was made. Required for member-submitted purchases (so
  /// the cost deducts from their custody balance). Heads recording
  /// directly may leave this null and deduct from the dept budget
  /// instead.
  custodyId       String?
  custody         Custody? @relation(fields: [custodyId], references: [id], onDelete: SetNull)

  /// "paid" | "unpaid"
  paymentStatus   String   @default("unpaid")

  /// V0.14 — approval status.
  ///   pending   — recorded by a dept member, awaits head approval.
  ///                Doesn't count toward Spent yet.
  ///   approved  — head approved (or head recorded it directly).
  ///                Counts toward Spent + Resources auto-link fires here.
  ///   rejected  — head rejected. Never counts toward Spent.
  status          String   @default("approved")
  approvedByUserId String?
  approvedAt      DateTime?
  rejectedAt      DateTime?
  rejectionReason String?

  createdByUserId String
  createdBy       User     @relation("PurchaseCreator", fields: [createdByUserId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // V0.22 — multi-line invoice support. Each PurchaseItem is one
  // line on the receipt and (when the parent category isResource)
  // becomes its own Equipment row.
  items           PurchaseItem[]

  @@index([projectId])
  @@index([departmentId])
  @@index([type])
  @@index([categoryKey])
  @@index([paymentStatus])
  @@index([createdByUserId])
  @@index([custodyId])
}

// ─── V0.22 — Purchase Line Items ────────────────────────────────────
//
// One PurchaseItem = one line on the invoice. The parent Purchase
// becomes the invoice container (vendor, date, total, receipt).
// When the parent category is isResource (or the parent has
// saveAsResource=true), each item auto-creates its own Equipment.
//
// Legacy Purchases (pre-V0.22) are back-filled with a single
// PurchaseItem mirroring their existing name / quantity / amount.

model PurchaseItem {
  id              String   @id @default(cuid())
  purchaseId      String
  purchase        Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  name            String
  /// How many of this item on the line. Minimum 1.
  quantity        Int      @default(1)
  /// Per-unit price in minor units. Optional — invoices sometimes
  /// list only a line total without breaking it down.
  unitPrice       Int?
  /// Line total in minor units (quantity * unitPrice, or manually
  /// entered when unit price isn't known). Required.
  lineTotal       Int

  /// V0.22 — auto-created Equipment row for this line, when the
  /// parent Purchase's category is isResource. Nullable + unique
  /// so a line links to at most one Equipment.
  equipmentId     String?  @unique

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([purchaseId])
}

// ─── V0.14.1 — Custody Requests ─────────────────────────────────────
//
// A team member asks for more cash. Head reviews and either approves
// (which mints a fresh Custody for that member) or rejects.

model CustodyRequest {
  id              String   @id @default(cuid())
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  departmentId    String
  department      Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  requesterUserId String
  requester       User     @relation("CustodyRequestRequester", fields: [requesterUserId], references: [id], onDelete: Cascade)

  /// Requested amount in minor units. Currency inherits from Project.
  amount          Int
  /// Why the member needs more cash.
  reason          String

  /// "pending" | "approved" | "rejected"
  status          String   @default("pending")

  decidedByUserId String?
  decidedBy       User?    @relation("CustodyRequestDecider", fields: [decidedByUserId], references: [id], onDelete: SetNull)
  decidedAt       DateTime?
  /// Reason supplied on reject (optional).
  decisionReason  String?
  /// When approved, the Custody created. Set by the approve endpoint.
  fulfilledCustodyId String? @unique

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([projectId])
  @@index([departmentId])
  @@index([requesterUserId])
  @@index([status])
}

// ─── V0.16 — Maintenance Records ──────────────────────────────────────
//
// A log of repair / inspection / calibration / cleaning events on a
// piece of equipment. Open records (completedAt is NULL) put the
// asset into "in_maintenance" status. Closing the record either
// returns the asset to "available" or escalates to a Damage Report.

model MaintenanceRecord {
  id            String   @id @default(cuid())
  equipmentId   String
  equipment     Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  createdByUserId String
  createdBy     User     @relation(fields: [createdByUserId], references: [id], onDelete: Cascade)

  /// "repair" | "inspection" | "calibration" | "cleaning" | "other"
  type          String
  /// Free-text vendor name (workshop, service provider).
  vendor        String?
  /// Cost in minor units. Currency = project's.
  cost          Int?
  notes         String?

  startedAt     DateTime @default(now())
  /// NULL while the maintenance is active (asset = in_maintenance).
  completedAt   DateTime?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([equipmentId])
  @@index([type])
  @@index([completedAt])
}

// ─── V0.17 — Scene Planning & Department Workflow ─────────────────────
//
// Scenes are the production-planning primitive. Each Scene is owned by
// a Project. Departments opt-in per scene via SceneDepartment (one
// row per scene-department combo). When all enabled depts are approved
// the scene auto-promotes to "ready".
//
// Future modules (Cast, Props, Equipment, Wardrobe, Makeup, Vehicles,
// Locations, Scheduling, Call Sheets, Reports) attach to Scene via
// new optional FKs / models — no rewrite of this schema needed.

model Scene {
  id              String   @id @default(cuid())
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  /// Editorial number. String so "1A" / "12B" work.
  number          String
  title           String
  description     String?
  location        String?
  /// "INT" | "EXT" | "INT_EXT"
  type            String   @default("INT")
  /// "day" | "night" | "dawn" | "dusk"
  timeOfDay       String   @default("day")
  /// "draft" | "planning" | "ready" | "scheduled" | "shot" | "completed"
  status          String   @default("draft")
  notes           String?
  /// JSON array of { title: string, url: string }
  attachments     Json?
  /// V0.19 — Gallery thumbnail. Only set by Director / AD / Producer
  /// / EP / Owner (canManageScene). When absent, Gallery view uses a
  /// status-coloured gradient placeholder.
  coverImageUrl   String?

  createdByUserId String
  createdBy       User     @relation("SceneCreator", fields: [createdByUserId], references: [id], onDelete: Cascade)
  updatedByUserId String?
  updatedBy       User?    @relation("SceneUpdater", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  departments     SceneDepartment[]
  // V0.18 — assets linked to this scene.
  assets          SceneAsset[]
  // V0.24 — Agency access.
  comments        SceneComment[]
  creativeApprovals CreativeApproval[]
  // V0.25 — cast linked to this scene.
  cast            SceneCast[]

  @@unique([projectId, number])
  @@index([projectId])
  @@index([status])
  @@index([type])
  @@index([timeOfDay])
}

/// V0.18 — SceneAsset: links a Scene to an existing Equipment (prop,
/// camera gear, costume, etc.). One link = "Scene #N needs X of this
/// asset". Cross-scene total vs Equipment.quantity drives the
/// shortage warning. No status here — keep it simple (V0.17 brief
/// confirmation from the user). Add later if needed.
model SceneAsset {
  id              String   @id @default(cuid())
  sceneId         String
  scene           Scene    @relation(fields: [sceneId], references: [id], onDelete: Cascade)
  equipmentId     String
  equipment       Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  /// How many of this equipment the scene needs. Min 1.
  quantityNeeded  Int      @default(1)
  notes           String?

  addedByUserId   String
  addedBy         User     @relation("SceneAssetAdder", fields: [addedByUserId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([sceneId, equipmentId])
  @@index([sceneId])
  @@index([equipmentId])
}

/// Per-department workspace inside a scene. Created on demand when a
/// department is toggled on. The row's presence + `enabled=true` is
/// what marks the dept as part of the scene workflow.
model SceneDepartment {
  id              String   @id @default(cuid())
  sceneId         String
  scene           Scene    @relation(fields: [sceneId], references: [id], onDelete: Cascade)
  departmentId    String
  department      Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  /// True when the dept is part of this scene's workflow.
  enabled         Boolean  @default(true)
  /// "not_started" | "in_progress" | "blocked" | "completed"
  status          String   @default("not_started")
  /// "pending_review" | "approved"
  approvalStatus  String   @default("pending_review")

  requirements    String?
  notes           String?
  /// JSON array of { title: string, url: string }
  attachments     Json?

  approvedByUserId String?
  approvedBy       User?    @relation("SceneDeptApprover", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  approvedAt       DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([sceneId, departmentId])
  @@index([sceneId])
  @@index([departmentId])
  @@index([status])
  @@index([approvalStatus])
}

// =============================================================
// V0.20 — Production Bible
// =============================================================
// A project-wide reference library every department contributes
// to. Each entry belongs to either a specific Department or the
// global "Direction & Production" pseudo-section (departmentId =
// NULL). Entries can be Text Notes (body), Links/Files (url), or
// both. Add/edit/delete is gated to the dept's head (or above);
// view is open to every project member.

model BibleEntry {
  id              String   @id @default(cuid())
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  /// NULL = "Direction & Production" (script, contracts, exec notes).
  /// Set = belongs to that department's section.
  departmentId    String?
  department      Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  title           String
  description     String?
  /// External link / file URL. Null when the entry is a pure text note.
  url             String?
  /// Long-form text body. Null when the entry is a pure link/file.
  body            String?
  /// "note" | "link" | "image" | "document" | "video" | "mood_board" | "other"
  type            String   @default("link")
  /// Floats to the top of its section when true.
  pinned          Boolean  @default(false)

  addedByUserId   String
  addedBy         User     @relation("BibleEntryAuthor", fields: [addedByUserId], references: [id], onDelete: Cascade)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([projectId])
  @@index([departmentId])
  @@index([pinned])
}

// =============================================================
// V0.23 — File Uploads (Supabase Storage)
// =============================================================
// Polymorphic attachment table — every uploadable feature points
// at it via (ownerType, ownerId). This replaces the ad-hoc
// `attachments Json` arrays that were scattered across models.
// Old JSON arrays stay for backwards compat with URL-paste
// entries; new uploads always create Attachment rows.
//
// Files live in Supabase Storage under
//   production-files/{projectId}/{ownerType}/{ownerId}/{uuid}-{name}
// storagePath is that key (relative to the bucket).

model Attachment {
  id              String   @id @default(cuid())
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  /// "scene" | "scene_dept" | "bible" | "purchase" | "equipment" | "user" | "custody" | "scene_cover"
  ownerType       String
  /// The id of the row this attachment belongs to.
  ownerId         String

  /// Original filename the user uploaded.
  fileName        String
  /// e.g. "image/jpeg" | "application/pdf" | "video/mp4".
  mimeType        String
  /// Bytes.
  size            Int
  /// Supabase Storage key (relative to the bucket).
  storagePath     String
  /// Optional preview image path (for images: a resized 400px webp).
  thumbnailPath   String?

  uploadedByUserId String
  uploadedBy       User    @relation("AttachmentUploader", fields: [uploadedByUserId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())

  @@index([projectId])
  @@index([ownerType, ownerId])
}

// =============================================================
// V0.24 — Agency Access
// =============================================================
// SceneComment: threaded feedback on a scene. Everyone in the
// project (including client roles) can post; only the author can
// delete. Feeds the "creative feedback" loop.
//
// CreativeApproval: a formal request from Director/AD to a client
// role (Creative Director, etc.) to sign off a milestone —
// casting picks, wardrobe direction, first cut, final cut, etc.
// Optional sceneId when the milestone is scene-specific.

model SceneComment {
  id              String   @id @default(cuid())
  sceneId         String
  scene           Scene    @relation(fields: [sceneId], references: [id], onDelete: Cascade)

  body            String

  authorId        String
  author          User     @relation("SceneCommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([sceneId])
  @@index([authorId])
}

model CreativeApproval {
  id              String   @id @default(cuid())
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  /// Optional scene link — some milestones (script sign-off, final
  /// cut) are project-wide, others (casting for Scene 5) are
  /// scene-scoped.
  sceneId         String?
  scene           Scene?   @relation(fields: [sceneId], references: [id], onDelete: SetNull)

  /// "script_signoff" | "treatment" | "casting" | "wardrobe" |
  /// "location" | "cut_v1" | "cut_final" | "other"
  kind            String
  title           String
  description     String?
  /// "pending" | "approved" | "rejected"
  status          String   @default("pending")

  requestedByUserId String
  requestedBy       User    @relation("CreativeApprovalRequester", fields: [requestedByUserId], references: [id], onDelete: Cascade)
  requestedAt       DateTime @default(now())

  decidedByUserId String?
  decidedBy       User?    @relation("CreativeApprovalDecider", fields: [decidedByUserId], references: [id], onDelete: SetNull)
  decidedAt       DateTime?
  decisionReason  String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([projectId])
  @@index([sceneId])
  @@index([status])
}

// =============================================================
// V0.25 — Cast / Talent
// =============================================================
// Talent = an actor / cast member on the project. Belongs to
// exactly one Department (usually Casting, but nothing enforces
// that so an agency-supplied Talent can live under Direction).
// SceneCast links a Talent to a Scene, mirroring V0.18 SceneAsset.
//
// Client-role visibility (agency): they see name / character /
// bio / headshot. Contact + dayRate are hidden by the API for
// them.

model Talent {
  id              String   @id @default(cuid())
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  departmentId    String
  department      Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  name            String
  /// Optional character(s) they play. Free text (comma-separated
  /// for now; may evolve to a Character model later).
  characterName   String?
  /// Short bio / description.
  bio             String?
  /// Headshot image URL — URL paste OR a Supabase Storage path
  /// from V0.23. Rendered inside the Talent card.
  headshotUrl     String?
  /// Business info — HIDDEN from client roles.
  contactPhone    String?
  contactEmail    String?
  agentName       String?
  agentContact    String?
  /// Day rate in minor units, in the project's currency.
  /// HIDDEN from client roles.
  dayRate         Int?

  /// V0.25 — link back to the auto-creating Purchase (rental or
  /// buy-out), when this Talent was born out of a "cast rental"
  /// purchase. Nullable + unique so a purchase creates at most
  /// one Talent record.
  purchaseId      String?  @unique

  createdByUserId String
  createdBy       User     @relation("TalentCreator", fields: [createdByUserId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  sceneLinks      SceneCast[]

  @@index([projectId])
  @@index([departmentId])
}

model SceneCast {
  id              String   @id @default(cuid())
  sceneId         String
  scene           Scene    @relation(fields: [sceneId], references: [id], onDelete: Cascade)
  talentId        String
  talent          Talent   @relation(fields: [talentId], references: [id], onDelete: Cascade)

  /// Character in this specific scene (may differ from Talent's
  /// default character — e.g. Lead in Scene 1, Cameo in Scene 6).
  characterName   String?
  /// Optional call time (crew arrives, actor arrives).
  callTime        DateTime?
  notes           String?

  addedByUserId   String
  addedBy         User     @relation("SceneCastAdder", fields: [addedByUserId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([sceneId, talentId])
  @@index([sceneId])
  @@index([talentId])
}
